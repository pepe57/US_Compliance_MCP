{
  "name": "@ansvar/us-regulations-mcp",
  "version": "1.1.0",
  "mcpName": "us.ansvar/us-regulations-mcp",
  "description": "MCP server for US cybersecurity and privacy regulations. Query HIPAA, CCPA, SOX, GLBA, FERPA, COPPA, FDA 21 CFR Part 11, EPA RMP, FFIEC, and NYDFS 500 directly from Claude.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "us-regulations-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist && find . -name '*.tsbuildinfo' -not -path './node_modules/*' -delete",
    "test": "tsx scripts/quality-test.ts && tsx scripts/test-remaining-tools.ts && tsx scripts/test-mcp-tools.ts && tsx scripts/test-ecfr-adapter.ts && tsx scripts/test-seed-adapters.ts && tsx scripts/test-v1.2-adapters.ts",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build:db": "tsx scripts/build-db.ts",
    "ingest": "tsx scripts/ingest.ts",
    "load-seed": "tsx scripts/load-seed-data.ts",
    "test:mcp": "tsx scripts/test-mcp-tools.ts",
    "lint": "eslint src --ext .ts",
    "prepare": "test -f dist/index.js || npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "compliance",
    "hipaa",
    "ccpa",
    "sox",
    "glba",
    "ferpa",
    "coppa",
    "fda",
    "epa",
    "ffiec",
    "nydfs",
    "us-regulations",
    "cybersecurity",
    "privacy",
    "healthcare",
    "financial-services",
    "education",
    "children-privacy",
    "pharmaceutical",
    "environmental",
    "banking",
    "sarbanes-oxley",
    "california-consumer-privacy-act",
    "gramm-leach-bliley",
    "pci-dss",
    "payment-card-security",
    "23-nycrr-500",
    "claude",
    "llm"
  ],
  "author": "Ansvar Systems <hello@ansvar.eu> (https://ansvar.eu)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/US_compliance_MCP.git"
  },
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/US_compliance_MCP/issues"
  },
  "homepage": "https://ansvar.eu",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "data",
    "scripts",
    "src"
  ],
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.0.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.3.3"
  }
}
